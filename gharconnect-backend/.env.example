# ─── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=gharconnect-prod
# Place your Firebase service account JSON at the path below
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json

# ─── Google Maps Platform ─────────────────────────────────────────────────────
# Restrict to: Geocoding API, Distance Matrix API, Static Maps API
GOOGLE_MAPS_API_KEY=AIza_YOUR_KEY_HERE

# ─── Twilio SMS ───────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_YOUR_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
TWILIO_FROM_NUMBER=+1415XXXXXXX

# ─── Agora RTC (Voice Calls) ──────────────────────────────────────────────────
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_CERTIFICATE

# ─── Google Cloud Tasks ───────────────────────────────────────────────────────
GCP_PROJECT_ID=gharconnect-prod
CLOUD_TASKS_LOCATION=asia-south1
CLOUD_TASKS_QUEUE_NAME=gharconnect-tasks
CLOUD_FUNCTIONS_BASE_URL=https://asia-south1-gharconnect-prod.cloudfunctions.net

# ─── Internal Security ────────────────────────────────────────────────────────
# Must be ≥ 32 random characters. Same value in Cloud Tasks task headers.
INTERNAL_SECRET=replace_with_32_char_secret_here!!

# ─── Razorpay (Post-MVP) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_RAZORPAY_SECRET

# ─── Free APIs (no key needed) ────────────────────────────────────────────────
# Open Holidays API: https://openholidaysapi.org/en (no key)
# ipapi.co: https://ipapi.co/api (no key for basic use)
