# ============================================
# GharConnect Backend — Environment Variables
# ============================================

# ─── Firebase (free — no card) ─────────────────────────────────────────────────
FIREBASE_PROJECT_ID=gharconnect-YOUR_PROJECT_ID
FIREBASE_STORAGE_BUCKET=gharconnect-YOUR_PROJECT_ID.appspot.com
# Place your Firebase service account JSON at the path below
GOOGLE_APPLICATION_CREDENTIALS=../serviceAccount.json

# ─── Twilio SMS (free $15 trial — no card) ────────────────────────────────────
TWILIO_ACCOUNT_SID=AC_YOUR_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_AUTH_TOKEN_HERE
TWILIO_FROM_NUMBER=+1415XXXXXXX

# ─── Agora Voice Calls (10,000 min/month free — no card) ──────────────────────
AGORA_APP_ID=YOUR_AGORA_APP_ID
AGORA_APP_CERTIFICATE=YOUR_AGORA_CERTIFICATE

# ─── Google Cloud Tasks (1M ops/month free — ⚠ card required) ─────────────────
GCP_PROJECT_ID=gharconnect-YOUR_PROJECT_ID
CLOUD_TASKS_LOCATION=asia-south1
CLOUD_TASKS_QUEUE_NAME=gharconnect-tasks
CLOUD_FUNCTIONS_BASE_URL=https://asia-south1-gharconnect-YOUR_PROJECT_ID.cloudfunctions.net

# ─── Internal Security ────────────────────────────────────────────────────────
# Must be ≥ 32 random characters. Same value in Cloud Tasks task headers.
INTERNAL_SECRET=GENERATE_RANDOM_32_CHAR_STRING_HERE

# ─── Free APIs (no keys needed — already work) ────────────────────────────────
OPEN_HOLIDAYS_BASE_URL=https://openholidaysapi.org
IPAPI_BASE_URL=https://ipapi.co
